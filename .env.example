# Copy to .env and fill in. Never commit real keys.
PROPLINE_API_KEY=

# Push alerts when mispriced opportunities appear (--poll)
# Phone (easiest): install ntfy app → subscribe to this topic
NTFY_TOPIC=ud-edge-fin-alerts
# Optional:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERT_WEBHOOK_URL=

# PropLine daily budget (default 5000)
# PROPLINE_DAILY_LIMIT=5000

# Optional fallbacks:
# SPORTSGAMEODDS_KEY=
# APISPORTS_KEY=
