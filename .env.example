# ============================================
# PropLine API (required for sharp odds)
# ============================================
PROPLINE_API_KEY=your_propline_api_key_here

# ============================================
# Notification Channels (all optional, any combination fires)
# ============================================

# NTFY: https://ntfy.sh — free push notifications, zero signup
NTFY_TOPIC=your_ntfy_topic_here

# Slack: incoming webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram: bot token from @BotFather + your chat ID
# Bot token:
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID (numeric or @channelname):
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord: incoming webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/discord/webhook

# Generic JSON webhook (any endpoint accepting {title, text, app})
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.example.com/alerts
